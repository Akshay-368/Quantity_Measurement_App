Jwt__Key="put your secret here"
Jwt__Issuer=QuantityMeasurementAPI
Jwt__Audience=QuantityMeasurementUsers

# Optional for local development. In Render set these in dashboard environment variables.
ConnectionStrings__DefaultConnection="Host=localhost;Database=quantitymeasurement;Port=5432;Username=postgres;Password=postgres;SSL Mode=Prefer;"
Redis__Configuration="localhost:6379"
Redis__InstanceName="QuantityMeasurementApp:"
CORS_ALLOWED_ORIGINS="https://your-frontend.onrender.com"